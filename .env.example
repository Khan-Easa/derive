# ─────────────────────────────────────────────
# Derivé Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to git.
#
# Lines starting with # are comments.
# Values don't need quotes unless they contain spaces.

# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
# Environment name: development | staging | production
ENVIRONMENT=development

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS origins allowed to call the backend (comma-separated)
# In dev, this will match your local frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─────────────────────────────────────────────
# LLM Provider API Keys
# ─────────────────────────────────────────────
# DeepSeek — primary reasoning model
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Anthropic — Claude Sonnet (fallback) & Claude Opus (judge)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI — optional fallback (not required for V1)
# OPENAI_API_KEY=your-openai-api-key-here

# ─────────────────────────────────────────────
# Databases
# ─────────────────────────────────────────────
# Relational DB — SQLite locally, PostgreSQL in production
# Dev (SQLite): sqlite+aiosqlite:///./derive.db
# Prod (PostgreSQL): postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./derive.db

# ChromaDB — vector database (embedded)
# Directory where ChromaDB persists its data
CHROMA_PERSIST_DIR=./chroma_db

# ─────────────────────────────────────────────
# Observability
# ─────────────────────────────────────────────
# Langfuse — LLM tracing and cost tracking
# Get from: https://cloud.langfuse.com (free tier)
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com